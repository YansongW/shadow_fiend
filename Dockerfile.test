# shadow_fiend 单元测试 Docker 镜像
# 说明：此镜像仅用于无 GUI、无音频硬件的单元测试，不能运行端到端 demo。

FROM python:3.11-slim

# Install system dependencies needed by PyAudio / ffmpeg / numpy
RUN apt-get update && apt-get install -y --no-install-recommends \
    portaudio19-dev \
    libsndfile1 \
    ffmpeg \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy dependency file first to leverage Docker cache
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy source code and tests
COPY src/ ./src/
COPY tests/ ./tests/
COPY scripts/ ./scripts/

# Default: run headless unit tests
CMD ["python", "scripts/test_runner.py", "test", "--headless"]
